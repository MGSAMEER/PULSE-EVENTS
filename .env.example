# Event Ticketing Backend - Environment Configuration
# Copy this file to .env and update values with your configuration

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/event-ticketing

# JWT Configuration
# Generate a secure random string for production (min 32 characters)
JWT_SECRET=your-jwt-secret-key

# Razorpay Payment Configuration
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email Configuration (Gmail)
# Note: Requires App Password if 2FA is enabled
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password

# CORS Configuration (Optional)
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Cloudinary Configuration (Required for sponsor image uploads)
# Get keys from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Logging Configuration
# LOG_LEVEL=debug|info|warn|error
LOG_LEVEL=debug
